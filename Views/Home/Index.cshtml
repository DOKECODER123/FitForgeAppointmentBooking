<!-- HOW IT WORKS -->
<div style="background:#2a2a2e; border:1px solid #3a3a3e; border-radius:20px; padding:48px; margin-bottom:72px; text-align:center;">
    <h2 style="font-size:34px; font-weight:800; color:#fff; margin-bottom:8px;">How it works</h2>
    <p style="color:#888; margin-bottom:40px;">Three steps and you're done.</p>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
        <div>
            <div style="width:52px; height:52px; background:#ff8c42; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:900; color:#fff; margin:0 auto 16px;">1</div>
            <h6 style="color:#fff; font-weight:700; margin-bottom:6px;">Fill the form</h6>
            <p style="color:#888; font-size:13px;">Enter your name, service, preferred date and time.</p>
        </div>
        <div>
            <div style="width:52px; height:52px; background:#2dd4bf; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:900; color:#0f2e2b; margin:0 auto 16px;">2</div>
            <h6 style="color:#fff; font-weight:700; margin-bottom:6px;">Submit</h6>
            <p style="color:#888; font-size:13px;">Your booking is saved instantly to our system.</p>
        </div>
        <div>
            <div style="width:52px; height:52px; background:#ff8c42; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:900; color:#fff; margin:0 auto 16px;">3</div>
            <h6 style="color:#fff; font-weight:700; margin-bottom:6px;">Get confirmed</h6>
            <p style="color:#888; font-size:13px;">Admin reviews and confirms your appointment slot.</p>
        </div>
    </div>
</div>

